{
    "manufacturer": "Sri",
    "keyboard_name": "Nexus_Pad",
    "maintainer": "ttayg-Sr",
    "url": "https://github.com/ttayG-sr/Nexus-Hackpad",
    "bootloader": "rp2040",
    "processor": "RP2040",
    "features": {
        "bootmagic" : true,
        "extrakey" : true,
        "mousekey" : true,
        "nkro" : true,
        "encoder" : true,
        "oled" : true,
        "rgblight" : true
    },
    "usb": {
            "vid": "0xFEED",
            "pid": "0x0000",
            "device_version": "1.0.0"
        },
            
    "matrix_pins": {
    "cols": ["GP26", "GP27", "GP28"],
    "rows": ["GP4", "GP2", "GP1"]
    },
    "diode_direction": "ROW2COL",
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0},
                {"matrix": [1, 0], "x": 0, "y": 1},
                {"matrix": [1, 1], "x": 1, "y": 1},
                {"matrix": [1, 2], "x": 2, "y": 1},
                {"matrix": [2, 0], "x": 0, "y": 2},
                {"matrix": [2, 1], "x": 1, "y": 2},
                {"matrix": [2, 2], "x": 2, "y": 2}
            ]
        }
    },
    "encoder": {
        "rotary": [
            {
                "pin_a": "GP29",
                "pin_b": "GP0"
            }
        ]
    },
    "ws2812": {
        "pin": "GP3",
        "driver": "vendor"
    },
    "rgblight": {
        "led_count": 9,
        "rgbw": true,
        "animations": {
            "breathing": true,
            "rainbow_mood": true,
            "snake": true
        }
    }

}    
