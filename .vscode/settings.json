{
  "C_Cpp.errorSquiggles": "Disabled",
  "C_Cpp.intelliSenseEngine": "Tag Parser",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/**",
    "/usr/local/include",
    "/usr/include",
    "${env:HOME}/qmk_firmware",
    "/usr/local/qmk_firmware"
  ],
  "C_Cpp.default.browse.path": [
    "${workspaceFolder}"
  ],
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}"
  ],
  "files.exclude": {
    "**/.DS_Store": true
  }
}
